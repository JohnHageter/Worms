# =============================================================================
# Base module hierarchy
# =============================================================================

class Module:
    def Port(self) -> Port: ...

class EventSupportingModule(Module): ...

class ModuleDescriptor:
    def ID(self) -> str: ...
    def DisplayName(self) -> str: ...
    def Vendor(self) -> str: ...
    def Model(self) -> str: ...
    def Version(self) -> str: ...

# =============================================================================
# Descriptors
# =============================================================================

class DeviceDescriptor(ModuleDescriptor):
    def OpenDevice(self, access_type: int) -> Device: ...

class InterfaceDescriptor(ModuleDescriptor):
    def OpenInterface(self) -> Interface: ...

class DataStreamDescriptor(ModuleDescriptor):
    def OpenDataStream(self) -> DataStream: ...

# =============================================================================
# Vector containers (structural)
# =============================================================================

T = TypeVar("T")

class VectorString(Sequence[str]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> str: ...

class VectorInt64(Sequence[int]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> int: ...

class VectorDouble(Sequence[float]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> float: ...

class VectorUInt8(Sequence[int]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> int: ...

class VectorDeviceDescriptor(Sequence[DeviceDescriptor]):
    def empty(self) -> bool: ...
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> DeviceDescriptor: ...

class VectorInterfaceDescriptor(Sequence[InterfaceDescriptor]):
    def empty(self) -> bool: ...
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> InterfaceDescriptor: ...

class VectorDataStreamDescriptor(Sequence[DataStreamDescriptor]):
    def empty(self) -> bool: ...
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> DataStreamDescriptor: ...

class VectorNodeMap(Sequence["NodeMap"]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> NodeMap: ...

class VectorEnumerationEntryNode(Sequence["EnumerationEntryNode"]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> EnumerationEntryNode: ...

class VectorBuffer(Sequence["Buffer"]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> Buffer: ...

class VectorBufferPart(Sequence["BufferPart"]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> BufferPart: ...

class VectorFirmwareUpdateInformation(Sequence["FirmwareUpdateInformation"]):
    def __len__(self) -> int: ...
    def __getitem__(self, index: int) -> FirmwareUpdateInformation: ...

# =============================================================================
# Device Manager
# =============================================================================

class DeviceManager:
    @staticmethod
    def Instance() -> DeviceManager: ...
    def Update(self) -> None: ...
    def Devices(self) -> VectorDeviceDescriptor: ...
    def Interfaces(self) -> VectorInterfaceDescriptor: ...

# =============================================================================
# Device hierarchy
# =============================================================================

class Device(EventSupportingModule):
    def RemoteDevice(self) -> RemoteDevice: ...
    def DataStreams(self) -> VectorDataStreamDescriptor: ...

class Interface(EventSupportingModule): ...

class RemoteDevice(Module):
    def NodeMaps(self) -> VectorNodeMap: ...

# =============================================================================
# Node / GenAPI system
# =============================================================================

class Node():
    def Name(self) -> str: ...
    def IsReadable(self) -> bool: ...
    def IsWriteable(self) -> bool: ...
    def Type(self) -> bool: ...

class BooleanNode(Node):
    def Value(self) -> bool: ...
    def SetValue(self, value: bool) -> None: ...

class IntegerNode(Node):
    def Value(self) -> int: ...
    def SetValue(self, value: int) -> None: ...
    def Minimum(self) -> int: ...
    def Maximum(self) -> int: ...

class FloatNode(Node):
    def Value(self) -> float: ...
    def SetValue(self, value: float) -> None: ...
    def Minimum(self) -> float: ...
    def Maximum(self) -> float: ...

class RegisterNode(Node):
    def Address(self) -> int: ...
    def Length(self) -> int: ...
    def Read(self, *args) -> "Sequence[int]": ...
    def Write(self, *args) -> "None": ...

class StringNode(Node):
    def Value(self) -> str: ...
    def SetValue(self, value: str) -> None: ...

class CommandNode(Node):
    def Execute(self) -> None: ...
    def IsDone(self) -> "bool": ...
    def WaitUntilDone(self, waitTimeout_ms: "Timeout" | int =500) -> "None": ...

class EnumerationEntryNode(Node):
    def Symbolic(self) -> str: ...

class EnumerationNode(Node):
    def CurrentEntry(self) -> EnumerationEntryNode: ...
    def SetCurrentEntry(self, name: str) -> None: ...
    def Entries(self) -> VectorEnumerationEntryNode: ...

class NodeMap:
    def FindNode(self, name: str) -> Node: ...

# =============================================================================
# Streaming / Buffers
# =============================================================================

class Port: ...
class PortURL: ...

class Buffer:
    def Width(self) -> int: ...
    def Height(self) -> int: ...
    def Size(self) -> int: ...
    def BasePtr(self) -> Any: ...
    def PixelFormat(self) -> int: ...

class BufferPart: ...
class BufferChunk: ...
class Metadata: ...

class ExtractedPayload:
    size: int
    data_ptr: Any
    data_size: int
    pixel_format: int

def _ExtractPayloadFromBuffer(buffer: Buffer) -> ExtractedPayload: ...
def _ExtractMetadataFromBuffer(buffer: Buffer) -> Metadata: ...

class DataStream(EventSupportingModule):
    INFINITE_NUMBER: int

    def StartAcquisition(self, *args) -> None: ...
    def StopAcquisition(self, stop_mode: int) -> None: ...
    def QueueBuffer(self, buffer: Buffer) -> None: ...
    def WaitForFinishedBuffer(self, timeout_ms: int) -> Buffer: ...
    def NumBuffersAnnouncedMinRequired(self) -> int: ...
    def Flush(self, mode: "int") -> "None": ...
    def AllocAndAnnounceBuffer(self, payload_size: int) -> Buffer: ...

# =============================================================================
# Image handling
# =============================================================================

class Image:
    @staticmethod
    def CreateFromSizeAndBuffer(
        pixel_format: int,
        data_ptr: Any,
        size: int,
        width: int,
        height: int,
    ) -> Image: ...
    def get_numpy_2D(self) -> Any: ...


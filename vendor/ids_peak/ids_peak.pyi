from typing import Any, Sequence, Protocol, TypeVar, overload

# =============================================================================
# Core library
# =============================================================================

class Library:
    @staticmethod
    def Initialize() -> None: ...
    @staticmethod
    def Close() -> None: ...
    
class Timeout(object): ...

# =============================================================================
# SWIG callback bases
# =============================================================================

class NodeChangedCallbackBase: ...
class SystemInterfaceFoundCallbackBase: ...
class InterfaceDeviceFoundCallbackBase: ...
class InterfaceDeviceReconnectedCallbackBase: ...
class InterfaceDeviceDisconnectedCallbackBase: ...
class InterfaceDeviceLostCallbackBase: ...

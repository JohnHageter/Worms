class FirmwareUpdateProgressObserverUpdateStepStartedCallbackBase: ...
class FirmwareUpdateProgressObserverUpdateStepProgressChangedCallbackBase: ...
class FirmwareUpdateProgressObserverUpdateStepFinishedCallbackBase: ...
class FirmwareUpdateProgressObserverUpdateFinishedCallbackBase: ...
